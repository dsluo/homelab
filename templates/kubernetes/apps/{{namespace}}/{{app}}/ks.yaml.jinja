---
apiVersion: kustomize.toolkit.fluxcd.io/v1
kind: Kustomization
metadata:
  name: &app {{app}}
spec:
  {% if volsync -%}
  dependsOn:
    - name: volsync
      namespace: volsync-system
  components:
    - ../../../../components/volsync
  {% endif -%}
  interval: 1h
  path: ./kubernetes/apps/{{namespace}}/{{app}}/{{component}}
  postBuild:
    substitute:
      APP: *app
      {% if volsync -%}
      VOLSYNC_CAPACITY: 5Gi
      {% endif -%}
    substituteFrom:
      - name: cluster-secrets
        kind: Secret
  prune: true
  sourceRef:
    kind: GitRepository
    name: flux-system
    namespace: flux-system
  targetNamespace: {{namespace}}
  wait: false
