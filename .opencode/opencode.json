{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "cilium bgp peers": "allow",
      "cilium bgp routes": "allow",
      "cilium config view": "allow",
      "cilium status *": "allow",
      "cilium version": "allow",
      "dig *": "allow",
      "flux build *": "allow",
      "flux check": "allow",
      "flux events *": "allow",
      "flux export *": "allow",
      "flux get *": "allow",
      "flux stats *": "allow",
      "flux trace *": "allow",
      "flux tree *": "allow",
      "flux version": "allow",
      "gh issue list *": "allow",
      "gh issue view *": "allow",
      "gh pr checks *": "allow",
      "gh pr diff *": "allow",
      "gh pr list *": "allow",
      "gh pr view *": "allow",
      "gh release list *": "allow",
      "gh release view *": "allow",
      "gh run list *": "allow",
      "gh run view *": "allow",
      "git blame *": "allow",
      "git branch": "allow",
      "git config --get *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git ls-files *": "allow",
      "git remote -v": "allow",
      "git rev-parse *": "allow",
      "git show *": "allow",
      "git status": "allow",
      "helm dependency list *": "allow",
      "helm get *": "allow",
      "helm history *": "allow",
      "helm list *": "allow",
      "helm search *": "allow",
      "helm show *": "allow",
      "helm status *": "allow",
      "helm template *": "allow",
      "helmfile diff *": "allow",
      "helmfile list *": "allow",
      "helmfile template *": "allow",
      "host *": "allow",
      "kubectl api-resources": "allow",
      "kubectl api-versions": "allow",
      "kubectl cluster-info": "allow",
      "kubectl config view": "allow",
      "kubectl describe *": "allow",
      "kubectl diff *": "allow",
      "kubectl explain *": "allow",
      "kubectl get *": "allow",
      "kubectl kustomize *": "allow",
      "kubectl logs *": "allow",
      "kubectl top *": "allow",
      "kubectl version": "allow",
      "kustomize build *": "allow",
      "kustomize version": "allow",
      "mise config *": "allow",
      "mise current *": "allow",
      "mise doctor": "allow",
      "mise ls *": "allow",
      "mise outdated": "allow",
      "mise where *": "allow",
      "nslookup *": "allow",
      "talosctl containers *": "allow",
      "talosctl disk": "allow",
      "talosctl dmesg *": "allow",
      "talosctl etcd members *": "allow",
      "talosctl etcd status *": "allow",
      "talosctl get *": "allow",
      "talosctl health": "allow",
      "talosctl interfaces *": "allow",
      "talosctl logs *": "allow",
      "talosctl memory *": "allow",
      "talosctl mounts *": "allow",
      "talosctl nodes": "allow",
      "talosctl processes *": "allow",
      "talosctl read *": "allow",
      "talosctl routes *": "allow",
      "talosctl services": "allow",
      "talosctl stats *": "allow",
      "talosctl time *": "allow",
      "talosctl version": "allow",
      "tofu fmt -check *": "allow",
      "tofu output *": "allow",
      "tofu plan *": "allow",
      "tofu providers *": "allow",
      "tofu show *": "allow",
      "tofu show": "allow",
      "tofu state list": "allow",
      "tofu state show *": "allow",
      "tofu validate": "allow",
      "tofu version": "allow",
      "tofu workspace list": "allow",
      "tofu workspace show": "allow",
      "*": "ask"
    }
  },
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      },
    },
    "grafana": {
      "type": "local",
      "command": [
        "mcp-grafana"
      ],
      "environment": {
        "GRAFANA_URL": "{env:GRAFANA_URL}",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": "{env:GRAFANA_SERVICE_ACCOUNT_TOKEN}"
      },
    },
    "searxng": {
      "type": "remote",
      "url": "https://search-mcp.spudkingdom.org/mcp",
    }
  }
}
