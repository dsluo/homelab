---
apiVersion: kustomize.toolkit.fluxcd.io/v1
kind: Kustomization
metadata:
  name: &app {{app}}
spec:
  {% if kopiur -%}
  dependsOn:
    - name: kopiur-repository
      namespace: kopiur-system
  components:
    - ../../../../components/kopiur
  {%- endif %}
  interval: 1h
  path: ./kubernetes/apps/{{namespace}}/{{app}}/{{component}}
  postBuild:
    substitute:
      APP: *app
      {% if kopiur -%}
      KOPIUR_CAPACITY: 5Gi
      KOPIUR_UID: "{{kopiur_uid}}"
      KOPIUR_GID: "{{kopiur_gid}}"
      {%- endif %}
    substituteFrom:
      - name: cluster-secrets
        kind: Secret
  prune: true
  sourceRef:
    kind: GitRepository
    name: flux-system
    namespace: flux-system
  targetNamespace: {{namespace}}
  wait: false
