{
    "files.associations": {
        "*.json5": "jsonc",
        "*.bu": "yaml",
        "*.ign": "json"
    },
    "yaml.schemas": {
        "Kubernetes": "./kubernetes/*.yaml"
    },
    "vs-kubernetes": {
        "vs-kubernetes.kubeconfig": "./kubeconfig",
        "vs-kubernetes.knownKubeconfigs": [
          "./kubeconfig"
      ]
    },
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv",
    "sops.configPath": "./.sops.yaml",
    "sops.creationEnabled": true
}
